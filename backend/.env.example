# Pydantic Settings env names match field names (case-insensitive).
# MongoDB
mongodb_uri=mongodb://localhost:27017
mongodb_db_name=private_c

# API
api_v1_prefix=/api/v1
cors_origins=*

# Gemini (Google AI)
gemini_api_key=
gemini_model=gemini-1.5-flash

# ElevenLabs
elevenlabs_api_key=
elevenlabs_default_voice_id=21m00Tcm4TlvDq8ikWAM

# Storage (TTS files; served at GET /api/v1/audio/stream/{id})
audio_storage_dir=./data/audio

# Public base URL for audio_url in JSON (no trailing slash)
public_base_url=http://127.0.0.1:8000

# redis_url=redis://localhost:6379/0
