{
  "manifest_version": 3,
  "name": "Private-C",
  "description": "Privacy companion that highlights tracking and threat signals while you browse.",
  "version": "1.0.0",
  "action": {
    "default_title": "Private-C",
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "dashboard/dist/index.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "permissions": [
    "storage",
    "tabs",
    "tts"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.elevenlabs.io/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/threat-warning.js"
      ],
      "css": [
        "content/threat-warning.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
