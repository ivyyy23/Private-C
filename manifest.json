{
  "manifest_version": 3,
  "name": "Private-C",
  "description": "Privacy companion that highlights tracking and threat signals while you browse.",
  "version": "1.0.0",
  "action": {
    "default_title": "Private-C",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/Logo.png",
      "32": "assets/Logo.png",
      "48": "assets/Logo.png",
      "128": "assets/Logo.png"
    }
  },
  "icons": {
    "16": "assets/Logo.png",
    "32": "assets/Logo.png",
    "48": "assets/Logo.png",
    "128": "assets/Logo.png"
  },
  "options_ui": {
    "page": "dashboard/dist/index.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "tts",
    "scripting",
    "webRequest",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "private_c_static",
        "enabled": true,
        "path": "rules/dnr_static.json"
      }
    ]
  },
  "host_permissions": [
    "<all_urls>",
    "https://api.elevenlabs.io/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/spa-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/threat-warning.js"],
      "css": ["content/threat-warning.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
