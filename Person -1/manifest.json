{
  "manifest_version": 3,
  "name": "Private-C Privacy Extension",
  "version": "1.0",
  "description": "Intelligent privacy shield and tracker monitor.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "cookies",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
