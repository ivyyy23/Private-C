# MongoDB connection (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/private_c

# API port
PORT=3847

# Google AI Studio / Gemini API key (never commit real values; copy this file to .env)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override (default gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Set to 1 to run without MongoDB (in-memory store; dev only)
# SKIP_MONGO=1

# Comma-separated hostnames for weekly https://{host}/privacy fetch + Gemini summary (optional)
# POLICY_MONITOR_HOSTS=example.com

# Integrations: extension POST /api/state and /api/site-evaluation (site-evaluation needs GEMINI_API_KEY).
# Optional extension state field serverApiBase = your API origin. ElevenLabs: dashboard UI + manifest host permission.
# Auth today is local chrome.storage; add OAuth/JWT backend for real accounts. Threat list: replace THREAT_HOSTS in background.js.
